diff --git a/csrc/libtorch_stable/attention/dsa/include/flashinfer/dsa_indexer/dsa_indexer_kernels.cuh b/csrc/libtorch_stable/attention/dsa/include/flashinfer/dsa_indexer/dsa_indexer_kernels.cuh
