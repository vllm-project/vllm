# Qwen3.5/3.6 GGUF + MTP Support auf Basis eines fertigen vllm-Images.
# GGUF-Maschinerie kommt aus dem OOT-Plugin (vllm-gguf-plugin, hier der
# Fork mit qwen35-Adapter); dieses Dockerfile legt nur die drei
# Core-Fixes des vllm-Forks darüber (Registry, IsHybrid/MRoPE, Spec-MTP).
FROM lmcache/vllm-openai:dev-cu129

# GGUF-Plugin mit qwen35-Support (Fork; sobald upstream gemerged:
# einfach "pip install vllm-gguf-plugin")
RUN pip install --no-cache-dir gguf \
    && pip install --no-cache-dir \
       git+https://github.com/efschu/vllm-gguf-plugin.git@qwen35-support

# Core-Fixes aus dem vllm-Fork (Branch qwen35-gguf-mtp)
COPY vllm/model_executor/models/qwen3_5.py /usr/local/lib/python3.12/dist-packages/vllm/model_executor/models/
COPY vllm/model_executor/models/registry.py /usr/local/lib/python3.12/dist-packages/vllm/model_executor/models/
COPY vllm/config/speculative.py /usr/local/lib/python3.12/dist-packages/vllm/config/

RUN find /usr/local/lib/python3.12/dist-packages/vllm -name '__pycache__' -type d -exec rm -rf {} + 2>/dev/null || true

RUN python3 -c "import vllm; print('vllm:', vllm.__version__)" \
    && python3 -c "from vllm_gguf_plugin.weights_adapter import Qwen35GGUFAdapter; print('qwen35 gguf adapter ok')"

CMD ["bash"]
