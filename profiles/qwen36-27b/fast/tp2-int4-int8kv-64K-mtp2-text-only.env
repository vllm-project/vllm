# Fast Qwen3.6 27B INT4 INT8 KV route
# Communication-aware long-context experiment for 4x RTX 3080 Ti PCIe hosts.

MODEL_FAMILY=qwen36
SERVED_NAME=qwen36-27b-int4-tp2-int8kv-64k-mtp2
TP_SIZE=2
QUANTIZATION=gptq_marlin
KV_CACHE_DTYPE=int8_per_token_head
MAX_MODEL_LEN=65536
GPU_UTIL=0.92
MAX_BATCHED_TOKENS=2048
MAX_NUM_SEQS=1
MTP_K=2
MESSAGE_TYPE=text-only
COMPATIBLE_MODES=fast,normal
PROFILE_GROUP=qwen36-27b
MODEL_VARIANT=int4
