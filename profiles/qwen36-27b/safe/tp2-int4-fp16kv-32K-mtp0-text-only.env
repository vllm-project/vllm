# Safe Qwen3.6 27B routes
# Conservative baseline routes for 4x RTX 3080 Ti 12GB PCIe hosts.
# Phase 1 values are intentionally modest until real machine benchmarks are available.

MODEL_FAMILY=qwen36
SERVED_NAME=qwen36-27b-int4-tp2-fp16kv-32k
TP_SIZE=2
QUANTIZATION=gptq_marlin
KV_CACHE_DTYPE=
MAX_MODEL_LEN=32768
GPU_UTIL=0.90
MAX_BATCHED_TOKENS=2048
MAX_NUM_SEQS=1
MTP_K=0
MESSAGE_TYPE=text-only
COMPATIBLE_MODES=safe,normal
PROFILE_GROUP=qwen36-27b
MODEL_VARIANT=int4
