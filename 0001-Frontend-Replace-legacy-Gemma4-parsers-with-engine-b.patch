+                # Tool call follows
+                (_TOOL_START_TAG, [_TOOL_START_TID]),
+                ("call:get_weather{city:", [_TOK[3], _TOK[4]]),
+                ('<|"|>Tokyo<|"|>}', [_QUOTE_TID, _TOK[5], _QUOTE_TID, _TOK[6]]),
+                (_TOOL_END_TAG, [_TOOL_END_TID]),
