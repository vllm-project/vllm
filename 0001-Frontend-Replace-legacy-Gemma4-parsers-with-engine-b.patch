+FULL_TOKEN_SEQUENCE_2.append((QUOTED_ID, '<|"|>'))
+FULL_TOKEN_SEQUENCE_2.append(TOOL_BODY_TOKENS_2A[11])  # }
+FULL_TOKEN_SEQUENCE_2.append((TOOL_CALL_END_ID, "<tool_call|>"))
