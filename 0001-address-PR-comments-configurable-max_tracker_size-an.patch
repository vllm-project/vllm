From 72e014f0f5cc2caa75e29017a91ce189080db6b6 Mon Sep 17 00:00:00 2001
From: Srinivasoo7 <158864704+Srinivasoo7@users.noreply.github.com>
Date: Sun, 1 Mar 2026 11:43:17 -0600
Subject: [PATCH 1/2] address PR comments: configurable max_tracker_size and
 avoid stats mutation

Signed-off-by: Srinivasoo7 <158864704+Srinivasoo7@users.noreply.github.com>
---
 vllm/v1/kv_offload/cpu.py           | 4 ++++
 vllm/v1/kv_offload/reuse_manager.py | 4 +---
 2 files changed, 5 insertions(+), 3 deletions(-)

diff --git a/vllm/v1/kv_offload/cpu.py b/vllm/v1/kv_offload/cpu.py
index d64fa2e..b50b34b 100644
--- a/vllm/v1/kv_offload/cpu.py
+++ b/vllm/v1/kv_offload/cpu.py
@@ -87,9 +87,13 @@ class CPUOffloadingSpec(OffloadingSpec):
 
             store_threshold = int(self.extra_config.get("store_threshold", 0))
             if store_threshold > 1:
+                max_tracker_size = int(
+                    self.extra_config.get("max_tracker_size", 64_000)
+                )
                 self._manager = FilteredOffloadingManager(
                     backing=self._manager,
                     store_threshold=store_threshold,
+                    max_tracker_size=max_tracker_size,
                 )
         return self._manager
 
diff --git a/vllm/v1/kv_offload/reuse_manager.py b/vllm/v1/kv_offload/reuse_manager.py
index 9f1575c..3c14de5 100644
--- a/vllm/v1/kv_offload/reuse_manager.py
+++ b/vllm/v1/kv_offload/reuse_manager.py
@@ -154,9 +154,7 @@ class FilteredOffloadingManager(OffloadingManager):
         return self._backing.complete_load(block_hashes)
 
     def get_stats(self) -> dict[str, Any]:
-        stats = self._backing.get_stats()
-        stats["stores_skipped"] = self.stores_skipped
-        return stats
+        return {**self._backing.get_stats(), "stores_skipped": self.stores_skipped}
 
     def complete_store(
         self, block_hashes: Iterable[BlockHash], success: bool = True
-- 
