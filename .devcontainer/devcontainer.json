{
  "name": "vLLM ROCm Dev (RX 6900 XT)",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",
  // Install vLLM's Python requirements after the container starts.
  // The actual vLLM build (HIP kernel compilation) is done manually via install-vllm.sh.
  "postCreateCommand": "bash -c 'for f in requirements/requirements-common.txt requirements/requirements-rocm.txt requirements.txt; do [ -f \"$f\" ] && pip install -r \"$f\" && echo \"Installed $f\"; done; echo \"Done. Run .devcontainer/install-vllm.sh to build vLLM.\"'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "ms-python.debugpy",
        "charliermarsh.ruff",
        "eamodio.gitlens"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3",
        "editor.formatOnSave": true,
        "python.analysis.typeCheckingMode": "basic"
      }
    }
  }
}
