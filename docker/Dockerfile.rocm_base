ARG BASE_IMAGE=ubuntu:24.04
ARG TRITON_BRANCH="0f380657"
ARG TRITON_REPO="https://github.com/ROCm/triton.git"
ARG FA_BRANCH="0e60e394"
ARG FA_REPO="https://github.com/Dao-AILab/flash-attention.git"
ARG AITER_BRANCH="v0.1.16.post5"
ARG AITER_REPO="https://github.com/ROCm/aiter.git"

# Sccache configuration - LOCAL DISK MODE
ARG SCCACHE_DOWNLOAD_URL

FROM ${BASE_IMAGE} AS base

ARG PYTORCH_ROCM_ARCH="gfx90a;gfx942;gfx950;gfx1100;gfx1101;gfx1200;gfx1201;gfx1150;gfx1151"
ENV PYTORCH_ROCM_ARCH="${PYTORCH_ROCM_ARCH}"
ARG AITER_ROCM_ARCH="gfx942;gfx950"
ENV AITER_ROCM_ARCH="${AITER_ROCM_ARCH}"
# Prebuild AITER kernels at wheel-build time (CDNA only). 1=on, 0=off.
ARG PREBUILD_KERNELS=0
ARG PYTHON_VERSION=3.14.6
ARG MAX_JOBS=128
ENV MAX_JOBS=${MAX_JOBS}

# Required for RCCL in ROCm7.1
ENV HSA_NO_SCRATCH_RECLAIM=1

RUN mkdir -p /app
WORKDIR /app
ENV DEBIAN_FRONTEND=noninteractive

# Install base dependencies
RUN apt-get update -y \
    && apt-get install -y software-properties-common build-essential git curl sudo vim less libopenmpi-dev libpci-dev pkg-config libdrm-dev

# Install UV first (only needs curl, no Python dependency)
RUN curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="/usr/local/bin" sh

# Install requested Python version via uv (standalone builds, no PPA dependency)
RUN uv python install ${PYTHON_VERSION}
RUN uv venv /opt/python --python ${PYTHON_VERSION} --seed
ENV PATH=/opt/python/bin:$PATH
ENV UV_PYTHON=/opt/python/bin/python
ENV UV_HTTP_TIMEOUT=500
ENV UV_INDEX_STRATEGY="unsafe-best-match"
ENV UV_LINK_MODE=copy

RUN uv pip install -U packaging 'cmake<4' ninja wheel 'setuptools<80' pybind11
RUN CMAKE_REAL=$(python3 -c "import cmake, os; print(os.path.join(os.path.dirname(cmake.__file__), 'data', 'bin', 'cmake'))") \
    && ln -sf "$CMAKE_REAL" /opt/python/bin/cmake
RUN apt-get update && apt-get install -y libjpeg-dev libsox-dev libsox-fmt-all sox && rm -rf /var/lib/apt/lists/*

# Install sccache - always enabled for local disk caching
ARG SCCACHE_DOWNLOAD_URL
RUN echo "Installing sccache for local disk caching..." \
    && SCCACHE_ARCH="x86_64" \
    && SCCACHE_VERSION="v0.14.0" \
    && SCCACHE_DL_URL="${SCCACHE_DOWNLOAD_URL:-https://github.com/mozilla/sccache/releases/download/${SCCACHE_VERSION}/sccache-${SCCACHE_VERSION}-${SCCACHE_ARCH}-unknown-linux-musl.tar.gz}" \
    && curl -L -o /tmp/sccache.tar.gz ${SCCACHE_DL_URL} \
    && tar -xzf /tmp/sccache.tar.gz -C /tmp \
    && mv /tmp/sccache-${SCCACHE_VERSION}-${SCCACHE_ARCH}-unknown-linux-musl/sccache /usr/bin/sccache \
    && chmod +x /usr/bin/sccache \
    && rm -rf /tmp/sccache.tar.gz /tmp/sccache-${SCCACHE_VERSION}-${SCCACHE_ARCH}-unknown-linux-musl \
    && sccache --version

# NOTE: sccache wrappers are created AFTER TheRock ROCm install (below)
# because clang++ path depends on rocm-sdk init

# Configure sccache for LOCAL DISK mode
# Cache will be mounted at build time via --mount=type=cache
ENV SCCACHE_DIR=/sccache
ENV SCCACHE_IDLE_TIMEOUT=0
ENV SCCACHE_CACHE_SIZE="50G"

###
### TheROCK install
###
ARG PIP_EXTRA_INDEX_URL=https://rocm.nightlies.amd.com/whl-multi-arch/
ENV PIP_EXTRA_INDEX_URL=${PIP_EXTRA_INDEX_URL}
ARG ROCM_SDK_VERSION=7.15.0a20260721
ARG TORCH_VERSION=2.12.0+rocm7.15.0a20260721
ARG TORCHAUDIO_VERSION=2.11.0+rocm7.15.0a20260721
ARG TORCHVISION_VERSION=0.27.0+rocm7.15.0a20260721
# DEVICE_EXTRAS: set to install device-specific packages (e.g. "device-all" or
# "gfx90a;gfx942;gfx950"). When unset, only base torch wheels are installed.
ARG DEVICE_EXTRAS
# Source build fallback repos (used when wheels are not available).
ARG PYTORCH_REPO="https://github.com/ROCm/pytorch.git"
ARG PYTORCH_BRANCH="release/2.11"
ARG PYTORCH_VISION_REPO="https://github.com/pytorch/vision.git"
ARG PYTORCH_VISION_BRANCH="v0.24.1"
ARG PYTORCH_AUDIO_REPO="https://github.com/pytorch/audio.git"
ARG PYTORCH_AUDIO_BRANCH="v2.9.0"
# USE_CUSTOM_TRITON: set to 1 (default) to build triton from source and remove
# any triton that came bundled with the PyTorch wheel. Set to 0 to keep the
# TheRock triton from the PyTorch wheel instead.
ARG USE_CUSTOM_TRITON=0

# Install ROCm SDK (--prerelease=allow needed for nightly versions like 7.14.0a20260624)
RUN uv pip install --prerelease=allow --index-url ${PIP_EXTRA_INDEX_URL} \
    "rocm[libraries,devel]${ROCM_SDK_VERSION:+==${ROCM_SDK_VERSION}}" \
    && rocm-sdk init

# Install PyTorch: try wheels first, build from source if not available.
# For nightlies, version strings include a date suffix (e.g. +rocm7.14.0a20260522),
# so we let uv resolve the best match rather than pinning an exact version.
RUN set -e; \
    TORCH_INSTALLED=0; \
    if [ -n "${ROCM_SDK_VERSION}" ]; then \
        echo "Trying PyTorch wheels from TheRock index..." \
        && if uv pip install --prerelease=allow --index-url ${PIP_EXTRA_INDEX_URL} \
                "torch==${TORCH_VERSION}" \
                "torchaudio==${TORCHAUDIO_VERSION}" \
                "torchvision==${TORCHVISION_VERSION}"; then \
            echo "PyTorch wheels installed successfully"; \
            python3 -c "import torch; print(f'  torch={torch.__version__}, hip={torch.version.hip}')"; \
            if [ "${USE_CUSTOM_TRITON}" = "1" ] && python3 -c "import triton" 2>/dev/null; then \
                echo "Removing TheRock triton (USE_CUSTOM_TRITON=1, will be replaced by from-source build)"; \
                pip uninstall -y triton triton-kernels; \
            fi; \
            TORCH_INSTALLED=1; \
        else \
            echo "PyTorch wheels not found, will build from source"; \
        fi; \
    fi; \
    if [ "${TORCH_INSTALLED}" = "0" ]; then \
        echo "Building PyTorch from source (${PYTORCH_REPO} @ ${PYTORCH_BRANCH})" \
        && apt-get update && apt-get install -y pkg-config liblzma-dev \
        && git clone ${PYTORCH_REPO} /tmp/pytorch \
        && cd /tmp/pytorch && git checkout ${PYTORCH_BRANCH} \
        && pip install -r requirements.txt && git submodule update --init --recursive \
        && python3 tools/amd_build/build_amd.py \
        && CMAKE_PREFIX_PATH=$(python3 -c 'import sys; print(sys.prefix)') \
           python3 setup.py bdist_wheel --dist-dir=dist \
        && uv pip install dist/*.whl \
        && rm -rf /tmp/pytorch \
        && echo "Building torchvision from source (${PYTORCH_VISION_REPO} @ ${PYTORCH_VISION_BRANCH})" \
        && git clone ${PYTORCH_VISION_REPO} /tmp/vision \
        && cd /tmp/vision && git checkout ${PYTORCH_VISION_BRANCH} \
        && python3 setup.py bdist_wheel --dist-dir=dist \
        && uv pip install dist/*.whl \
        && rm -rf /tmp/vision \
        && echo "Building torchaudio from source (${PYTORCH_AUDIO_REPO} @ ${PYTORCH_AUDIO_BRANCH})" \
        && git clone ${PYTORCH_AUDIO_REPO} /tmp/audio \
        && cd /tmp/audio && git checkout ${PYTORCH_AUDIO_BRANCH} \
        && git submodule update --init --recursive \
        && pip install -r requirements.txt \
        && python3 setup.py bdist_wheel --dist-dir=dist \
        && uv pip install dist/*.whl \
        && rm -rf /tmp/audio; \
    fi

# Install device-specific packages when DEVICE_EXTRAS is set.
SHELL ["/bin/bash", "-c"]
RUN if [ -n "${DEVICE_EXTRAS}" ] && [ -n "${ROCM_SDK_VERSION}" ]; then \
        if echo "${ROCM_SDK_VERSION}" | grep -q '\.dev0'; then \
            ROCM_TORCH_SUFFIX="+devrocm$(echo ${ROCM_SDK_VERSION} | tr '+' '.')"; \
        else \
            ROCM_TORCH_SUFFIX="+rocm${ROCM_SDK_VERSION}"; \
        fi; \
        TORCH_VER="${TORCH_VERSION}${ROCM_TORCH_SUFFIX}"; \
        TORCHVISION_VER="${TORCHVISION_VERSION}${ROCM_TORCH_SUFFIX}"; \
        IFS=';' read -ra ARCHES <<< "${DEVICE_EXTRAS}"; \
        DEVICE_PKGS=""; \
        for arch in "${ARCHES[@]}"; do \
            if [ "$arch" = "device-all" ]; then \
                echo "Installing all device packages"; \
            else \
                DEVICE_PKGS="${DEVICE_PKGS} amd-torch-device-${arch}==${TORCH_VER}"; \
                DEVICE_PKGS="${DEVICE_PKGS} amd-torchvision-device-${arch}==${TORCHVISION_VER}"; \
                DEVICE_PKGS="${DEVICE_PKGS} rocm-sdk-device-${arch}==${ROCM_SDK_VERSION}"; \
            fi; \
        done; \
        if [ -n "${DEVICE_PKGS}" ]; then \
            echo "Installing device packages: ${DEVICE_PKGS}" \
            && uv pip install --prerelease=allow --index-url ${PIP_EXTRA_INDEX_URL} ${DEVICE_PKGS}; \
        fi; \
    fi
SHELL ["/bin/sh", "-c"]

RUN SITE_PACKAGES=$(python3 -c "import sysconfig; print(sysconfig.get_path('purelib'))") \
    && echo "SITE_PACKAGES=${SITE_PACKAGES}" \
    && echo "${SITE_PACKAGES}" > /tmp/site_packages_path \
    && ln -sf "${SITE_PACKAGES}" /opt/python/site-packages
ENV SITE_PACKAGES=/opt/python/site-packages
ENV ROCM_PATH="$SITE_PACKAGES/_rocm_sdk_devel" \
    ROCM_HOME="$SITE_PACKAGES/_rocm_sdk_devel" \
    HIP_PATH="$SITE_PACKAGES/_rocm_sdk_devel" \
    HIP_CLANG_PATH="$SITE_PACKAGES/_rocm_sdk_devel/lib/llvm/bin" \
    HIP_DEVICE_LIB_PATH="$SITE_PACKAGES/_rocm_sdk_core/lib/llvm/amdgcn/bitcode"
ENV LD_LIBRARY_PATH="$SITE_PACKAGES/_rocm_sdk_devel/lib:$SITE_PACKAGES/_rocm_sdk_devel/lib/rocm_sysdeps/lib:$SITE_PACKAGES/_rocm_sdk_core/lib:$SITE_PACKAGES/_rocm_sdk_core/lib/rocm_sysdeps/lib"
ENV PATH="$SITE_PACKAGES/_rocm_sdk_devel/bin:$SITE_PACKAGES/_rocm_sdk_devel/lib/llvm/bin:$SITE_PACKAGES/_rocm_sdk_core/bin:${PATH}"
RUN cd $SITE_PACKAGES/_rocm_sdk_core/share/amd_smi && uv pip install .
ENV PYTHONPATH=$SITE_PACKAGES/_rocm_sdk_core/share/amd_smi:$PYTHONPATH

# Setup sccache wrappers for HIP compilation via HIP_CLANG_PATH
# Must run AFTER rocm-sdk init so clang++ is installed
RUN echo "Setting up sccache wrappers for HIP compilation..." \
        && mkdir -p /opt/sccache-wrappers \
        && REAL_CLANGXX="" \
        && for p in \
             "${ROCM_PATH}/lib/llvm/bin/clang++" \
             "${ROCM_PATH}/bin/clang++" \
             "/opt/rocm/lib/llvm/bin/clang++" \
             "/opt/rocm/llvm/bin/clang++" \
             "$(which clang++ 2>/dev/null || true)"; do \
             if [ -n "$p" ] && [ -x "$p" ]; then REAL_CLANGXX="$p"; break; fi; \
           done \
        && REAL_CLANG="" \
        && for p in \
             "${ROCM_PATH}/lib/llvm/bin/clang" \
             "${ROCM_PATH}/bin/clang" \
             "/opt/rocm/lib/llvm/bin/clang" \
             "/opt/rocm/llvm/bin/clang" \
             "$(which clang 2>/dev/null || true)"; do \
             if [ -n "$p" ] && [ -x "$p" ]; then REAL_CLANG="$p"; break; fi; \
           done \
        && echo "Found clang++: ${REAL_CLANGXX}" \
        && echo "Found clang:   ${REAL_CLANG}" \
        && if [ -z "$REAL_CLANGXX" ]; then echo "ERROR: clang++ not found"; exit 1; fi \
        && printf '#!/bin/bash\nsccache %s "$@"\nret=$?\nif [ $ret -eq 2 ] || [ $ret -eq 254 ]; then\n  exec %s "$@"\nfi\nexit $ret\n' \
             "${REAL_CLANGXX}" "${REAL_CLANGXX}" > /opt/sccache-wrappers/clang++ \
        && chmod +x /opt/sccache-wrappers/clang++ \
        && printf '#!/bin/bash\nsccache %s "$@"\nret=$?\nif [ $ret -eq 2 ] || [ $ret -eq 254 ]; then\n  exec %s "$@"\nfi\nexit $ret\n' \
             "${REAL_CLANG}" "${REAL_CLANG}" > /opt/sccache-wrappers/clang \
        && chmod +x /opt/sccache-wrappers/clang \
        && echo "sccache wrappers created (with fallback):" \
        && cat /opt/sccache-wrappers/clang++

###
### Triton Build (from source when USE_CUSTOM_TRITON=1)
###
FROM base AS build_triton
ARG TRITON_BRANCH
ARG TRITON_REPO
ARG USE_CUSTOM_TRITON
RUN mkdir -p /app/install && \
    if [ "${USE_CUSTOM_TRITON}" != "1" ]; then \
        echo "USE_CUSTOM_TRITON=0: skipping triton source build (using TheRock triton)"; \
    else \
        git clone ${TRITON_REPO} \
        && cd triton \
        && git checkout ${TRITON_BRANCH} \
        && git config --global user.email "you@example.com" && git config --global user.name "Your Name" \
        && git cherry-pick 555d04f \
        && if [ ! -f setup.py ]; then cd python; fi \
        && python3 setup.py bdist_wheel --dist-dir=dist \
        && cp dist/*.whl /app/install; \
    fi
RUN if [ "${USE_CUSTOM_TRITON}" = "1" ] && [ -d triton/python/triton_kernels ]; then \
        pip install build && cd triton/python/triton_kernels \
        && python3 -m build --wheel && cp dist/*.whl /app/install; \
    fi


###
### FlashAttention Build
###
FROM base AS build_fa
ARG FA_BRANCH
ARG FA_REPO
RUN git clone ${FA_REPO}
RUN --mount=type=cache,target=/sccache \
    cd flash-attention \
    && git checkout ${FA_BRANCH} \
    && git submodule update --init \
    && export HIP_CLANG_PATH=/opt/sccache-wrappers \
    && echo "sccache stats before build:" \
    && sccache --show-stats \
    && FILTERED_ARCHS=$(echo ${PYTORCH_ROCM_ARCH} | sed -e 's/;*gfx1[0-9]\{3\}//g' -e 's/^gfx1[0-9]\{3\};*//g') \
    && if [ -z "$FILTERED_ARCHS" ] || [ "$FILTERED_ARCHS" = ";" ]; then \
           echo "RDNA-only build: building flash-attention without GPU_ARCHS (Triton backend)" \
           && python3 setup.py bdist_wheel --dist-dir=dist; \
       else \
           echo "CDNA build: building flash-attention with GPU_ARCHS=$FILTERED_ARCHS" \
           && GPU_ARCHS=$FILTERED_ARCHS python3 setup.py bdist_wheel --dist-dir=dist; \
       fi \
    && echo "sccache stats after build:" \
    && sccache --show-stats
RUN mkdir -p /app/install && cp /app/flash-attention/dist/*.whl /app/install


###
### AITER Build (CDNA only -- skipped for RDNA targets)
###
FROM base AS build_aiter
ARG AITER_BRANCH
ARG AITER_REPO
RUN --mount=type=cache,target=/sccache \
    mkdir -p /app/install && \
    if [ -z "${AITER_ROCM_ARCH}" ] || echo "${AITER_ROCM_ARCH}" | grep -qvE "gfx9"; then \
        echo "Skipping aiter build for RDNA target (AITER_ROCM_ARCH=${AITER_ROCM_ARCH})"; \
    else \
        git clone --recursive ${AITER_REPO} \
        && cd aiter \
        && git checkout ${AITER_BRANCH} \
        && git submodule update --init --recursive \
        && uv pip install -r requirements.txt \
        && uv pip install pyyaml \
        && export HIP_CLANG_PATH=/opt/sccache-wrappers \
        && echo "sccache stats before build:" \
        && sccache --show-stats \
        && AITER_USE_SYSTEM_TRITON=1 PREBUILD_KERNELS=${PREBUILD_KERNELS} GPU_ARCHS=${AITER_ROCM_ARCH} python3 setup.py bdist_wheel --dist-dir=dist \
        && echo "sccache stats after build:" \
        && sccache --show-stats \
        && ls /app/aiter/dist/*.whl \
        && cp /app/aiter/dist/*.whl /app/install/; \
    fi


###
### Final Build
###

# Wheel release stage -
# only includes dependencies used by wheel release pipeline
FROM base AS debs_wheel_release
RUN mkdir /app/debs
RUN --mount=type=bind,from=build_triton,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs 2>/dev/null || echo "No triton wheels (USE_CUSTOM_TRITON=0)"
RUN --mount=type=bind,from=build_fa,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs
RUN --mount=type=bind,from=build_aiter,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs 2>/dev/null || echo "No aiter wheels (RDNA build)"

FROM base AS debs
RUN mkdir /app/debs
RUN --mount=type=bind,from=build_triton,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs 2>/dev/null || echo "No triton wheels (USE_CUSTOM_TRITON=0)"
RUN --mount=type=bind,from=build_fa,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs
RUN --mount=type=bind,from=build_aiter,src=/app/install/,target=/install \
    cp /install/*.whl /app/debs 2>/dev/null || echo "No aiter wheels (RDNA build)"

FROM base AS final
RUN --mount=type=bind,from=debs,src=/app/debs,target=/install \
    uv pip install /install/*.whl

ARG BASE_IMAGE
ARG TRITON_BRANCH
ARG TRITON_REPO
ARG FA_BRANCH
ARG FA_REPO
ARG AITER_BRANCH
ARG AITER_REPO
RUN echo "BASE_IMAGE: ${BASE_IMAGE}" > /app/versions.txt \
    && echo "TRITON_BRANCH: ${TRITON_BRANCH}" >> /app/versions.txt \
    && echo "TRITON_REPO: ${TRITON_REPO}" >> /app/versions.txt \
    && echo "FA_BRANCH: ${FA_BRANCH}" >> /app/versions.txt \
    && echo "FA_REPO: ${FA_REPO}" >> /app/versions.txt \
    && echo "AITER_BRANCH: ${AITER_BRANCH}" >> /app/versions.txt \
    && echo "AITER_REPO: ${AITER_REPO}" >> /app/versions.txt
